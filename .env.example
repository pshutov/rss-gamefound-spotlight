# GitHub repo (owner/repo)
REPO_SLUG=yourname/rss-gamefound-spotlight
CODE_BRANCH=main

# Git identity for commits to gh-pages
GIT_USER_NAME=Deploy Bot
GIT_USER_EMAIL=noreply@example.com

# RSS output filename (e.g. gamefound_spotlight.xml)
RSS_OUTPUT_PATH=gamefound_spotlight.xml
USE_DB=false

# Required secrets (set in Dokploy UI or server .env, do not commit)
# GH_PAT=github_pat_...  — GitHub token with repo push access
# CRON_TOKEN=random_secret — protects /run endpoint; use in Schedule Job curl

# Optional
# GF_API=https://gamefound.com/api/...  — override Gamefound API URL
# PORT=10000  — app port (default 10000)
