# GitHub repo (owner/repo) — used to clone code; when using Supabase Storage, push to gh-pages is skipped
REPO_SLUG=yourname/rss-gamefound-spotlight
CODE_BRANCH=main

# RSS output filename (e.g. gamefound_spotlight.xml)
RSS_OUTPUT_PATH=gamefound_spotlight.xml
USE_DB=false

# Supabase Storage (optional): if set, RSS is uploaded here instead of pushing to gh-pages. No GH_PAT needed.
# In Supabase Dashboard: Storage → New bucket (e.g. "rss"), set Public, optionally set file size limit for the bucket.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (or SUPABASE_KEY) — secret, do not commit
# SUPABASE_BUCKET=rss
# SUPABASE_STORAGE_PATH=gamefound_spotlight.xml
# SUPABASE_MAX_FILE_BYTES=1048576  (default 1 MiB; reject upload if RSS exceeds this)

# Required when NOT using Supabase (gh-pages path): set in Dokploy UI, do not commit
# GH_PAT=github_pat_...  — GitHub token with repo push access
# GIT_USER_NAME=Deploy Bot
# GIT_USER_EMAIL=noreply@example.com
# CRON_TOKEN=random_secret — protects /run endpoint; use in Schedule Job curl

# Optional
# GF_API=https://gamefound.com/api/...  — override Gamefound API URL
# PORT=10000  — app port (default 10000)
